# Base URL for the HKBiaoge Rust API (exposed to the browser). Keep this as /api so
# the browser calls the API same-origin — no CORS and no OPTIONS preflight. It is
# forwarded to the real API by either the Next.js rewrite (see API_PROXY_TARGET) or,
# in mainland prod, the nginx reverse proxy (see nginx.conf).
NEXT_PUBLIC_API_URL=/api

# Upstream the Next.js rewrite proxies /api/* to (server-side only; NOT exposed to
# the browser). Set this for local dev and any environment where Next serves /api
# directly (e.g. overseas users hitting Cloud Run). Leave unset when an external
# proxy (nginx) already handles /api/*.
# API_PROXY_TARGET=http://localhost:4040/api_v1.2

# Optional: POST client errors here (swap for Sentry later). Leave unset to disable.
# NEXT_PUBLIC_ERROR_REPORT_URL=https://your-collector.example.com/errors
